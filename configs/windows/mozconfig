# === Cross-compile-only block (GCB: Linux + Wine + VS2022) ===
if test "$ZEN_CROSS_COMPILING"; then

  export WINSYSROOT="$(echo ~)/win-cross/vs2026"

  export WINE="$(echo ~)/win-cross/wine/bin/wine"
  export WINEDEBUG=-all

  export MOZ_STUB_INSTALLER=1
  export MOZ_PKG_FORMAT=TAR

  export CROSS_BUILD=1
  CROSS_COMPILE=1

  if test "$SURFER_COMPAT" = "aarch64"; then
    export WIN32_REDIST_DIR="$(echo ~)/win-cross/vs2026/VC/Redist/MSVC/14.50.35710/arm64/Microsoft.VC145.CRT"
  else
    export WIN32_REDIST_DIR="$(echo ~)/win-cross/vs2026/VC/Redist/MSVC/14.50.35710/x64/Microsoft.VC145.CRT"
  fi

  # sccache wrapping clang-cl through wine is broken (clang-cl gets invoked
  # without input files). Disable ccache/sccache for C/C++ on cross-compile only.
  # Native Windows builds (GHA) DO NOT set this flag and CAN use sccache.
  ac_add_options --without-ccache
fi

# === Shared block (applies to both cross-compile and native Windows builds) ===

ac_add_options --disable-maintenance-service
ac_add_options --disable-bits-download

# wasi-sdk (used to sandbox libgraphite/libexpat via RLBox) is not staged
# on the native-GHA runner. Cross-compile (GCB) container has it via
# the upstream Mozilla toolchain tarball; native builds here don't.
# Configure even suggests this exact flag as the workaround.
if test ! "$WINSYSROOT"; then
  ac_add_options --without-wasm-sandboxed-libraries

  # The Gecko Profiler rust-api crate uses bindgen against MSVC STL
  # headers; the resulting bindings.rs fails to compile on the
  # native-GHA runner's MSVC 14.44 toolset (build script exits 101
  # without surfacing a usable error to cargo's persisted output
  # files). Profiler is a developer-only tool, not user-facing.
  # Disable on native builds; GCB cross-compile keeps it enabled.
  ac_add_options --disable-gecko-profiler

  # WebRTC stays ENABLED on native builds. The earlier --disable-webrtc
  # was a workaround for a libwebrtc link failure ("No rule to make target
  # Unified_cpp_e_levels_adjuster_gn0.obj") whose real cause was generic
  # GNU make (choco) mangling backslashes in libwebrtc's deeply-nested
  # paths. The native build now uses mozmake (Mozilla's path-aware make;
  # see .github/workflows/windows-native-build.yml), which links libwebrtc
  # correctly. Disabling WebRTC had stripped navigator.mediaDevices, which
  # broke sites that fingerprint it (e.g. x.com login).
fi

if test "$SURFER_COMPAT" = "x86_64"; then
  ac_add_options --target=x86_64-pc-windows-msvc
  # wmfcdm requires the Windows App SDK; the cross-compile (GCB) path
  # picks it up via WINSYSROOT, but native Windows builds don't have a
  # pre-staged SDK on this runner. Enable wmfcdm only when WINSYSROOT
  # is set (i.e. ZEN_CROSS_COMPILING). Native runs use widevine only,
  # which matches arm64 / linux / macos configs in this repo.
  if test "$WINSYSROOT"; then
    ac_add_options --enable-eme=widevine,wmfcdm
  else
    ac_add_options --enable-eme=widevine
  fi
elif test "$SURFER_COMPAT" = "aarch64"; then
  ac_add_options --target=aarch64-pc-windows-msvc
  ac_add_options --enable-eme=widevine

  # arm64 LTO override (applies to both cross and native cross-target builds)
  export MOZ_LTO=cross,thin
  ac_add_options --enable-lto=cross,thin
fi

# === PGO block (flattened — works for both cross and native paths) ===
# Three modes, selected by two env vars:
#   ZEN_GA_GENERATE_PROFILE=1                  -> Stage 1 (instrument)
#   ZEN_GA_DISABLE_PGO=1                       -> no PGO (arm64 always, debug builds)
#   neither set                                -> Stage 3 (profile-use), requires merged.profdata
#
# PGO data location:
#   Native GHA pipeline sets NEVOFLUX_PGO_PROFILE_DIR explicitly to MSYS path of
#   $GITHUB_WORKSPACE/pgo-cache. The $HOME/artifact fallback exists for GCB
#   backward compatibility (GCB does cp /workspace/merged.profdata $HOME/artifact/).
#   DO NOT remove the fallback -- it would silently break GCB.

if test "$ZEN_GA_GENERATE_PROFILE" -a "$SURFER_COMPAT" = "x86_64"; then
  mk_add_options "export MOZ_AUTOMATION_PACKAGE_GENERATED_SOURCES=0"
  ac_add_options --enable-profile-generate=cross
elif test "$SURFER_COMPAT" = "x86_64" -a ! "$ZEN_GA_DISABLE_PGO"; then
  PGO_DIR="${NEVOFLUX_PGO_PROFILE_DIR:-$(echo ~)/artifact}"
  if test -f "$PGO_DIR/merged.profdata"; then
    ac_add_options --enable-profile-use=cross
    ac_add_options --with-pgo-profile-path="$PGO_DIR/merged.profdata"
    ac_add_options --with-pgo-jarlog="$PGO_DIR/en-US.log"
  fi
fi
# aarch64: no PGO under any path (both cross and native)
