[
  {
    "namespace": "nevoflux",
    "description": "NevoFlux browser automation and data extraction API",
    "types": [
      {
        "id": "ApiResult",
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "error": { "$ref": "ApiError", "optional": true }
        }
      },
      {
        "id": "ApiError",
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "message": { "type": "string" },
          "recoverable": { "type": "boolean" },
          "suggestion": { "type": "string", "optional": true }
        }
      },
      {
        "id": "SnapshotOptions",
        "type": "object",
        "properties": {
          "interactive": { "type": "boolean", "optional": true },
          "compact": { "type": "boolean", "optional": true },
          "depth": { "type": "integer", "optional": true },
          "root": { "type": "string", "optional": true },
          "useA11y": { "type": "boolean", "optional": true },
          "domFallback": { "type": "boolean", "optional": true },
          "include_hidden": { "type": "boolean", "optional": true },
          "viewport_only": { "type": "boolean", "optional": true }
        }
      },
      {
        "id": "SnapshotResult",
        "type": "object",
        "properties": {
          "tree": { "type": "string" },
          "refs": { "type": "object" },
          "viewportInfo": { "type": "object", "optional": true },
          "stats": { "type": "object", "optional": true },
          "url": { "type": "string", "optional": true },
          "title": { "type": "string", "optional": true }
        }
      },
      {
        "id": "ScreenshotOptions",
        "type": "object",
        "properties": {
          "fullPage": { "type": "boolean", "optional": true },
          "type": { "type": "string", "enum": ["png", "jpeg"], "optional": true },
          "quality": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "ScreenshotResult",
        "type": "object",
        "properties": {
          "image": { "type": "string" },
          "mimeType": { "type": "string" },
          "width": { "type": "integer" },
          "height": { "type": "integer" }
        }
      },
      {
        "id": "ClickOptions",
        "type": "object",
        "properties": {
          "button": { "type": "string", "enum": ["left", "right", "middle"], "optional": true },
          "clickCount": { "type": "integer", "optional": true },
          "delay": { "type": "integer", "optional": true },
          "force": { "type": "boolean", "optional": true }
        }
      },
      {
        "id": "TypeOptions",
        "type": "object",
        "properties": {
          "delay": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "WaitOptions",
        "type": "object",
        "properties": {
          "timeout": { "type": "integer", "optional": true },
          "state": { "type": "string", "enum": ["visible", "hidden", "attached", "detached"], "optional": true }
        }
      },
      {
        "id": "NavigationOptions",
        "type": "object",
        "properties": {
          "timeout": { "type": "integer", "optional": true },
          "waitUntil": { "type": "string", "enum": ["load", "domcontentloaded", "networkidle"], "optional": true }
        }
      },
      {
        "id": "FilterResult",
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "filteredCount": { "type": "integer" },
          "filtered": { "type": "boolean" }
        }
      },
      {
        "id": "PrivacyConfig",
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "filters": { "type": "object" },
          "mode": { "type": "string" },
          "scope": { "type": "string" }
        }
      },
      {
        "id": "TabInfo",
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "url": { "type": "string" },
          "title": { "type": "string" },
          "active": { "type": "boolean" },
          "index": { "type": "integer" },
          "windowId": { "type": "integer" },
          "status": { "type": "string" }
        }
      },
      {
        "id": "TabCreateOptions",
        "type": "object",
        "properties": {
          "url": { "type": "string", "optional": true },
          "active": { "type": "boolean", "optional": true },
          "windowId": { "type": "integer", "optional": true },
          "index": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "TabQueryFilter",
        "type": "object",
        "properties": {
          "active": { "type": "boolean", "optional": true },
          "url": { "type": "string", "optional": true },
          "title": { "type": "string", "optional": true },
          "windowId": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "WindowCreateOptions",
        "type": "object",
        "properties": {
          "url": { "type": "string", "optional": true },
          "incognito": { "type": "boolean", "optional": true },
          "width": { "type": "integer", "optional": true },
          "height": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "KeyPressOptions",
        "type": "object",
        "properties": {
          "modifiers": { "type": "array", "items": { "type": "string" }, "optional": true },
          "delay": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "MouseButtonOptions",
        "type": "object",
        "properties": {
          "button": { "type": "string", "enum": ["left", "right", "middle"], "optional": true }
        }
      },
      {
        "id": "WheelOptions",
        "type": "object",
        "properties": {
          "deltaX": { "type": "integer", "optional": true },
          "deltaY": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "DragOptions",
        "type": "object",
        "properties": {
          "steps": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "Cookie",
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" },
          "domain": { "type": "string" },
          "path": { "type": "string" },
          "secure": { "type": "boolean" },
          "httpOnly": { "type": "boolean" },
          "sameSite": { "type": "string" },
          "expirationDate": { "type": "number", "optional": true }
        }
      },
      {
        "id": "CookieSetOptions",
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "name": { "type": "string" },
          "value": { "type": "string" },
          "domain": { "type": "string", "optional": true },
          "path": { "type": "string", "optional": true },
          "secure": { "type": "boolean", "optional": true },
          "httpOnly": { "type": "boolean", "optional": true },
          "sameSite": { "type": "string", "optional": true },
          "expirationDate": { "type": "number", "optional": true }
        }
      },
      {
        "id": "CookieFilter",
        "type": "object",
        "properties": {
          "url": { "type": "string", "optional": true },
          "name": { "type": "string", "optional": true },
          "domain": { "type": "string", "optional": true }
        }
      },
      {
        "id": "CaptureOptions",
        "type": "object",
        "properties": {
          "urlPattern": { "type": "string", "optional": true },
          "resourceTypes": { "type": "array", "items": { "type": "string" }, "optional": true },
          "recordBody": { "type": "boolean", "optional": true }
        }
      },
      {
        "id": "CapturedRequest",
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "method": { "type": "string" },
          "resourceType": { "type": "string" },
          "headers": { "type": "object" },
          "status": { "type": "integer", "optional": true },
          "timestamp": { "type": "number" },
          "requestBody": { "type": "string", "optional": true },
          "responseBody": { "type": "string", "optional": true }
        }
      },
      {
        "id": "MockResponse",
        "type": "object",
        "properties": {
          "status": { "type": "integer", "optional": true },
          "headers": { "type": "object", "optional": true },
          "body": { "type": "string", "optional": true }
        }
      },
      {
        "id": "InterceptOptions",
        "type": "object",
        "properties": {
          "urlPattern": { "type": "string" },
          "resourceTypes": { "type": "array", "items": { "type": "string" }, "optional": true },
          "handler": { "type": "string", "enum": ["block", "mock", "modify"] },
          "mockResponse": { "$ref": "MockResponse", "optional": true },
          "modifyHeaders": { "type": "object", "optional": true }
        }
      },
      {
        "id": "EvalOptions",
        "type": "object",
        "properties": {
          "returnValue": { "type": "boolean", "optional": true },
          "timeout": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "EvalResult",
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "value": { "type": "any", "optional": true },
          "type": { "type": "string", "optional": true },
          "error": { "$ref": "ApiError", "optional": true }
        }
      },
      {
        "id": "FrameInfo",
        "type": "object",
        "properties": {
          "selector": { "type": "string" },
          "url": { "type": "string" },
          "name": { "type": "string" },
          "visible": { "type": "boolean" }
        }
      },
      {
        "id": "DownloadResult",
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "url": { "type": "string", "optional": true },
          "filename": { "type": "string", "optional": true },
          "mimeType": { "type": "string", "optional": true },
          "size": { "type": "integer", "optional": true },
          "error": { "$ref": "ApiError", "optional": true }
        }
      },
      {
        "id": "DownloadOptions",
        "type": "object",
        "properties": {
          "timeout": { "type": "integer", "optional": true }
        }
      },
      {
        "id": "TabContent",
        "type": "object",
        "description": "Page content extraction result",
        "properties": {
          "tabId": { "type": "integer" },
          "url": { "type": "string" },
          "title": { "type": "string" },
          "content": { "type": "string" },
          "format": { "type": "string", "enum": ["markdown", "html", "text"] },
          "extractedAt": { "type": "integer" },
          "wasDiscarded": { "type": "boolean" }
        }
      },
      {
        "id": "TabState",
        "type": "object",
        "description": "Tab loading state",
        "properties": {
          "discarded": { "type": "boolean" },
          "status": { "type": "string", "enum": ["complete", "loading", "unloaded"] },
          "url": { "type": "string" },
          "title": { "type": "string" }
        }
      },
      {
        "id": "PickerResult",
        "type": "object",
        "description": "Element picker selection result",
        "properties": {
          "selector": { "type": "string" },
          "xpath": { "type": "string" },
          "tagName": { "type": "string" },
          "id": { "type": "string", "optional": true },
          "className": { "type": "string", "optional": true },
          "text": { "type": "string", "optional": true },
          "attributes": { "type": "object" },
          "rect": { "type": "object" }
        }
      },
      {
        "id": "SelectionData",
        "type": "object",
        "description": "Text selection data",
        "properties": {
          "text": { "type": "string" },
          "html": { "type": "string" },
          "rect": { "type": "object" },
          "anchorNode": { "type": "string" },
          "url": { "type": "string" },
          "title": { "type": "string" }
        }
      },
      {
        "id": "TabContentOptions",
        "type": "object",
        "description": "Options for getTabContent",
        "properties": {
          "format": { "type": "string", "enum": ["markdown", "html", "text"], "optional": true },
          "selector": { "type": "string", "optional": true },
          "autoRestore": { "type": "boolean", "optional": true },
          "timeout": { "type": "integer", "optional": true },
          "includeImages": { "type": "boolean", "optional": true, "description": "Include images in markdown output (default: false)" },
          "includeLinks": { "type": "boolean", "optional": true, "description": "Preserve links in markdown output (default: true)" },
          "removeNavigation": { "type": "boolean", "optional": true, "description": "Remove nav/header/footer elements (default: true)" }
        }
      },
      {
        "id": "MarkdownOptions",
        "type": "object",
        "description": "Options for getMarkdown",
        "properties": {
          "selector": { "type": "string", "optional": true, "description": "CSS selector to extract from" },
          "includeImages": { "type": "boolean", "optional": true, "description": "Include images in output (default: false)" },
          "includeLinks": { "type": "boolean", "optional": true, "description": "Preserve links in output (default: true)" },
          "removeNavigation": { "type": "boolean", "optional": true, "description": "Remove nav/header/footer elements (default: true)" }
        }
      },
      {
        "id": "PickerOptions",
        "type": "object",
        "description": "Options for pickElement",
        "properties": {
          "hint": { "type": "string", "optional": true },
          "filter": { "type": "string", "enum": ["any", "button", "input", "link", "image", "clickable"], "optional": true },
          "timeout": { "type": "integer", "optional": true },
          "highlightColor": { "type": "string", "optional": true }
        }
      },
      {
        "id": "LockPageOptions",
        "type": "object",
        "description": "Options for lockPage",
        "properties": {
          "showOverlay": { "type": "boolean", "optional": true },
          "message": { "type": "string", "optional": true }
        }
      }
    ],
    "functions": [
      {
        "name": "getVersion",
        "type": "function",
        "async": "promise",
        "description": "Get API version",
        "parameters": [],
        "returns": { "type": "string" }
      },
      {
        "name": "getText",
        "type": "function",
        "async": "promise",
        "description": "Get element text content",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "selector", "type": "string", "optional": true }
        ],
        "returns": { "type": "string" }
      },
      {
        "name": "getHtml",
        "type": "function",
        "async": "promise",
        "description": "Get element innerHTML",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "selector", "type": "string", "optional": true }
        ],
        "returns": { "type": "string" }
      },
      {
        "name": "getValue",
        "type": "function",
        "async": "promise",
        "description": "Get form element value",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "selector", "type": "string" }
        ],
        "returns": { "type": "string" }
      },
      {
        "name": "getUrl",
        "type": "function",
        "async": "promise",
        "description": "Get current page URL",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true }
        ],
        "returns": { "type": "string" }
      },
      {
        "name": "getTitle",
        "type": "function",
        "async": "promise",
        "description": "Get page title",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true }
        ],
        "returns": { "type": "string" }
      },
      {
        "name": "snapshot",
        "type": "function",
        "async": "promise",
        "description": "Get accessibility tree snapshot",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "options", "$ref": "SnapshotOptions", "optional": true }
        ],
        "returns": { "$ref": "SnapshotResult" }
      },
      {
        "name": "screenshot",
        "type": "function",
        "async": "promise",
        "description": "Take page screenshot",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "options", "$ref": "ScreenshotOptions", "optional": true }
        ],
        "returns": { "$ref": "ScreenshotResult" }
      },
      {
        "name": "getMarkdown",
        "type": "function",
        "async": "promise",
        "description": "Get page content as Markdown using Turndown with GFM tables",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "options", "$ref": "MarkdownOptions", "optional": true }
        ],
        "returns": { "type": "object" }
      },
      {
        "name": "isVisible",
        "type": "function",
        "async": "promise",
        "description": "Check if element is visible",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "selector", "type": "string" }
        ],
        "returns": { "type": "boolean" }
      },
      {
        "name": "exists",
        "type": "function",
        "async": "promise",
        "description": "Check if element exists",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "selector", "type": "string" }
        ],
        "returns": { "type": "boolean" }
      },
      {
        "name": "click",
        "type": "function",
        "async": "promise",
        "description": "Click element",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "selector", "type": "string" },
          { "name": "options", "$ref": "ClickOptions", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "type",
        "type": "function",
        "async": "promise",
        "description": "Type text into element",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "selector", "type": "string" },
          { "name": "text", "type": "string" },
          { "name": "options", "$ref": "TypeOptions", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "fill",
        "type": "function",
        "async": "promise",
        "description": "Fill form field",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "selector", "type": "string" },
          { "name": "text", "type": "string" }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "open",
        "type": "function",
        "async": "promise",
        "description": "Navigate to URL",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "url", "type": "string" },
          { "name": "options", "$ref": "NavigationOptions", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "reload",
        "type": "function",
        "async": "promise",
        "description": "Reload page",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "options", "$ref": "NavigationOptions", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "back",
        "type": "function",
        "async": "promise",
        "description": "Go back in history",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "forward",
        "type": "function",
        "async": "promise",
        "description": "Go forward in history",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "waitForSelector",
        "type": "function",
        "async": "promise",
        "description": "Wait for element",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true },
          { "name": "selector", "type": "string" },
          { "name": "options", "$ref": "WaitOptions", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "waitForTimeout",
        "type": "function",
        "async": "promise",
        "description": "Wait for specified time",
        "parameters": [
          { "name": "ms", "type": "integer" }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "filterSensitive",
        "type": "function",
        "async": "promise",
        "description": "Filter sensitive information from text",
        "parameters": [
          { "name": "text", "type": "string" },
          { "name": "options", "type": "object", "optional": true }
        ],
        "returns": { "$ref": "FilterResult" }
      },
      {
        "name": "getPrivacyConfig",
        "type": "function",
        "async": "promise",
        "description": "Get privacy configuration",
        "parameters": [],
        "returns": { "$ref": "PrivacyConfig" }
      },
      {
        "name": "setPrivacyConfig",
        "type": "function",
        "async": "promise",
        "description": "Update privacy configuration",
        "parameters": [
          { "name": "config", "$ref": "PrivacyConfig" }
        ],
        "returns": { "$ref": "PrivacyConfig" }
      },
      {
        "name": "createTab",
        "type": "function",
        "async": "promise",
        "description": "Create a new browser tab",
        "parameters": [
          { "name": "options", "$ref": "TabCreateOptions", "optional": true }
        ],
        "returns": { "$ref": "TabInfo" }
      },
      {
        "name": "closeTab",
        "type": "function",
        "async": "promise",
        "description": "Close a browser tab",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "getTab",
        "type": "function",
        "async": "promise",
        "description": "Get information about a tab",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true }
        ],
        "returns": { "$ref": "TabInfo" }
      },
      {
        "name": "queryTabs",
        "type": "function",
        "async": "promise",
        "description": "Query tabs matching filter criteria",
        "parameters": [
          { "name": "filter", "$ref": "TabQueryFilter", "optional": true }
        ],
        "returns": { "type": "array", "items": { "$ref": "TabInfo" } }
      },
      {
        "name": "activateTab",
        "type": "function",
        "async": "promise",
        "description": "Activate (focus) a browser tab",
        "parameters": [
          { "name": "tabId", "type": "integer", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "listTabs",
        "type": "function",
        "async": "promise",
        "description": "List all open tabs",
        "parameters": [],
        "returns": { "type": "array", "items": { "$ref": "TabInfo" } }
      },
      {
        "name": "createWindow",
        "type": "function",
        "async": "promise",
        "description": "Create a new browser window",
        "parameters": [
          { "name": "options", "$ref": "WindowCreateOptions", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "closeWindow",
        "type": "function",
        "async": "promise",
        "description": "Close a browser window",
        "parameters": [
          { "name": "windowId", "type": "integer", "optional": true }
        ],
        "returns": { "$ref": "ApiResult" }
      },
      {
        "name": "keyPress",
        "type": "function",
        "async": "promise",
        "description": "Press a keyboard key (keydown + keyup)",
