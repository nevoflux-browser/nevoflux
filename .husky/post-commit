#!/bin/sh

# Post-commit hook: Restore src/zen/ after pre-commit reverted it.
# Runs apply-patches.sh to re-copy overlays and inject NevoFlux customizations.
# This is safe because:
#   - engine/ symlinks to src/zen/ are intact (surfer import created them)
#   - apply-patches.sh operations are idempotent (sed checks, overlay copies)
#   - No nfpatch files (jar-inc-mn replaced with sed injection)

OVERLAYS_DIR="src/nevoflux/overlays"
NEED_RESTORE=false

if [ -d "$OVERLAYS_DIR" ]; then
    for file in $(find "$OVERLAYS_DIR" -type f 2>/dev/null); do
        relative_path="${file#$OVERLAYS_DIR/}"
        target_file="src/zen/$relative_path"
        if [ ! -f "$target_file" ]; then
            NEED_RESTORE=true
            break
        fi
    done
fi

if [ "$NEED_RESTORE" = true ]; then
    echo ""
    echo "============================================================"
    echo "  Restoring src/zen/ for continued development..."
    echo "============================================================"
    echo ""

    if [ -f "src/nevoflux/apply-patches.sh" ]; then
        bash src/nevoflux/apply-patches.sh
        echo ""
        echo "============================================================"
        echo "  src/zen/ restored. Ready for continued development."
        echo "============================================================"
    else
        echo "NOTE: Run 'npm run import' to restore src/zen/ for development."
    fi
fi
