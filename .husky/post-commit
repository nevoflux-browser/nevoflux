#!/bin/sh

# Post-commit hook: Notify developer if src/zen/ needs restoration
# The pre-commit hook reverts overlay/patch changes in src/zen/ before committing.
# After committing, developers should run `npm run import` to restore the working state.
#
# NOTE: We intentionally do NOT auto-run apply-patches.sh here because it
# requires the full engine symlink chain (created by surfer import) to work.
# Running it without surfer import leads to broken symlinks and blank UI.

OVERLAYS_DIR="src/nevoflux/overlays"
NEED_RESTORE=false

if [ -d "$OVERLAYS_DIR" ]; then
    for file in $(find "$OVERLAYS_DIR" -type f 2>/dev/null); do
        relative_path="${file#$OVERLAYS_DIR/}"
        target_file="src/zen/$relative_path"
        if [ ! -f "$target_file" ]; then
            NEED_RESTORE=true
            break
        fi
    done
fi

if [ "$NEED_RESTORE" = true ]; then
    echo ""
    echo "============================================================"
    echo "  src/zen/ was reverted for clean commit."
    echo "  Run 'npm run import' to restore for development."
    echo "============================================================"
fi
