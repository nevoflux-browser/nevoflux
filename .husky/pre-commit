#!/bin/sh

# Check for uncommitted changes in src/zen/
# These changes must be exported as patches before committing
# This hook will automatically revert src/zen/ changes

# Get staged files in src/zen/
ZEN_STAGED=$(git diff --cached --name-only | grep "^src/zen/" || true)

# Get unstaged changes in src/zen/
ZEN_UNSTAGED=$(git diff --name-only | grep "^src/zen/" || true)

# Check for untracked files in src/zen/ (overlay copies)
ZEN_UNTRACKED=$(git ls-files --others --exclude-standard src/zen/ 2>/dev/null || true)

# Combine all
ZEN_CHANGES="${ZEN_STAGED}${ZEN_UNSTAGED}${ZEN_UNTRACKED}"

if [ -n "$ZEN_CHANGES" ]; then
    echo ""
    echo "============================================================"
    echo "  Detected changes in src/zen/ - auto-reverting..."
    echo "============================================================"
    echo ""

    # Run revert script with auto-confirm
    if [ -f "./scripts/revert-zen-changes.sh" ]; then
        ./scripts/revert-zen-changes.sh -y

        # Re-check if there are still staged changes in src/zen/
        ZEN_STILL_STAGED=$(git diff --cached --name-only | grep "^src/zen/" || true)
        if [ -n "$ZEN_STILL_STAGED" ]; then
            echo ""
            echo "WARNING: Still have staged changes in src/zen/ after revert."
            echo "Unstaging these files..."
            git restore --staged src/zen/
        fi

        echo ""
        echo "============================================================"
        echo "  src/zen/ reverted. Continuing with commit..."
        echo "============================================================"
        echo ""
    else
        echo "ERROR: revert-zen-changes.sh not found!"
        echo "Please run manually: ./scripts/revert-zen-changes.sh"
        exit 1
    fi
fi

# Run lint-staged
npx lint-staged
